<idea-plugin>
    <id>com.provenance.recorder</id>
    <name>Provenance Recorder</name>
    <vendor email="provenance@example.edu" url="https://example.edu">Provenance</vendor>

    <description><![CDATA[
    Records a tamper-evident log of editing activity for an activated course
    assignment. Activates only on a workspace with a valid, course-signed
    .provenance-manifest. See the Provenance project documentation.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!--
      Optional, structurally-gated wiring (Plan 7). Each config-file is loaded ONLY when
      the named plugin is present; the classes it registers reference that plugin's types
      directly, so they are never classloaded on an IDE lacking the plugin (avoiding
      NoClassDefFoundError — the documented pattern, stronger than a runtime guard).
      Terminal/Git absence therefore degrades gracefully: the signal is simply not emitted.
    -->
    <depends optional="true" config-file="provjet-terminal.xml">org.jetbrains.plugins.terminal</depends>
    <depends optional="true" config-file="provjet-git.xml">Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Balloon group for disk-full degraded-mode disclosure (PRD §4.8). Resolved by id
             string directly (DegradedModeNotifier.GROUP_ID); no NotificationGroupManager lookup. -->
        <notificationGroup id="Provenance Recorder" displayType="BALLOON"/>
        <postStartupActivity implementation="dev.provenance.recorder.activation.RecorderActivationActivity"/>
        <statusBarWidgetFactory
            id="ProvenanceRecordingWidget"
            implementation="dev.provenance.recorder.statusbar.RecordingStatusBarWidgetFactory"
            order="first"/>
        <editorActionHandler
            action="EditorPaste"
            implementationClass="dev.provenance.recorder.wiring.paste.PasteInterceptHandlerFactory"/>
    </extensions>

    <actions>
        <!-- UI trigger for the bundle seal (PRD §4.6), the JetBrains analogue of the VS Code
             recorder's provenance.prepareSubmissionBundle command. Enabled only while a session
             is active; the seal work runs off the EDT (see PrepareSubmissionBundleAction). -->
        <action
            id="dev.provenance.recorder.PrepareSubmissionBundle"
            class="dev.provenance.recorder.commands.PrepareSubmissionBundleAction"
            text="Provenance: Prepare Submission Bundle"
            description="Seal the recorded provenance log and reviewed files into a submission bundle.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
